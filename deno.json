{
	"name": "@ts-series/smake",
	"version": "2.0",
	"author": "Enrico Rippin <e@rippin.org>",
	"description": "A lightweight CLI tool for automated generation of SQLite databases from multiple source files.",
	"license": "Unlicense",
	"exports": "./src/cli.ts",
	"compilerOptions": {
		"strict": true
	},
	"tasks": {
		"compile": "deno compile --allow-read --allow-write --allow-env --allow-ffi --output bin/smake src/cli.ts",
		"install": "deno task compile && cp bin/smake ~/.local/bin/smake",
		"dev": "DENO_DIR=.deno deno run --allow-env --allow-run --allow-ffi --allow-net --allow-read --allow-write --watch=src src/cli.ts",
		"test": "cd test && deno run --allow-read --allow-write --allow-env --allow-ffi ../src/cli.ts"
	},
	"imports": {
		"sqlite": "jsr:@db/sqlite@0.13",
		"std": "jsr:@std",
		"zod": "jsr:@zod/zod@^4.3.6"
	}
}